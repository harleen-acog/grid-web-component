{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationDir": "./dist",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true
  },
  "include": ["src/core/**/*", "src/query/**/*", "src/ui/**/*", "src/utils/**/*", "types/**/*"],
  "exclude": ["src/duck-grid.js", "src/duck-grid_*.js", "src/styles.js", "node_modules", "dist"]
}
