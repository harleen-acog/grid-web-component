{
  "name": "@aganitha/duck-grid",
  "version": "0.2.9",
  "description": "A generic data grid Web Component powered by DuckDB WASM. Accepts any Parquet or CSV file.",
  "type": "module",
  "module": "./dist/duck-grid.esm.js",
  "main": "./dist/duck-grid.cjs",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/duck-grid.esm.js",
      "require": "./dist/duck-grid.cjs",
      "default": "./dist/duck-grid.esm.js"
    },
    "./react": "./types/react.d.ts",
    "./vue": "./types/vue.d.ts"
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "web-component",
    "duckdb",
    "data-grid",
    "parquet",
    "csv",
    "wasm"
  ],
  "peerDependencies": {
    "@duckdb/duckdb-wasm": "^1.29.0"
  },
  "devDependencies": {
    "@duckdb/duckdb-wasm": "^1.29.0",
    "vite": "^5.4.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
